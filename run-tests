#!/usr/bin/env bash
set -euo pipefail

BATS_BIN="${BATS_BIN:-/opt/homebrew/bin/bats}"

if ! command -v bats &>/dev/null && [[ ! -x "${BATS_BIN}" ]]; then
  echo "Error: bats is not installed or not found." >&2
  echo "" >&2
  echo "Install it with:" >&2
  echo "  brew install bats-core" >&2
  exit 1
fi

BATS="$(command -v bats 2>/dev/null || echo "${BATS_BIN}")"

# If any argument is a file/directory path (not a flag), pass args directly
# to bats without the default --recursive tests/ so the file isn't run twice.
has_path_arg=false
for arg in "$@"; do
  [[ "${arg}" != --* ]] && has_path_arg=true && break
done

if [[ "${has_path_arg}" == false ]]; then
  exec "${BATS}" --recursive tests/ "$@"
else
  exec "${BATS}" "$@"
fi
